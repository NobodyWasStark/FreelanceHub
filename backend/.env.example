PORT=5000
NODE_ENV=development

# Database Connections (Neon Postgres)
# Transaction pool connection (used for application runtime queries)
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require&pgbouncer=true"

# Direct connection (used ONLY for running Prisma migrations)
DIRECT_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# Security (Must be at least 32 random characters)
JWT_SECRET="generate_a_secure_random_string_here_32_chars_min"

# CORS / Frontend Domain Integration
FRONTEND_URL="http://localhost:5173"